# Database Configuration
# For local development, SQLite is used by default
# For production, use PostgreSQL connection string
DATABASE_URL=sqlite:///./reports.db
# DATABASE_URL=postgresql://user:password@localhost:5432/waste_management

# Google AI Configuration (REQUIRED)
# Get your API key from https://ai.google.dev/
GOOGLE_API_KEY=your-google-generativeai-key-here

# Admin API Key (REQUIRED)
# Use a strong, random key (min 16 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=your-secure-admin-key-here-min-16-chars

# Application Configuration
DEBUG=False
API_TITLE=Waste Management Monitoring System API

# Rate Limiting (optional, defaults shown)
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REPORTS_PER_MINUTE=10
RATE_LIMIT_ADMIN_PER_MINUTE=100

# Background Jobs
AUTO_EXPIRY_INTERVAL_HOURS=6
REPORT_EXPIRY_DAYS=30

# CORS Configuration (optional)
# CORS_ORIGINS=["http://localhost:3000", "http://localhost:8501"]
